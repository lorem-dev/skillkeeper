{
  "name": "skillkeeper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Install and manage skills and hooks for AI coding agents",
  "license": "Apache-2.0",
  "author": "Lorem Dev",
  "homepage": "https://github.com/lorem-dev/skillkeeper",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "postinstall": "node scripts/gen-i18n.mjs",
    "dev": "node scripts/gen-i18n.mjs && pnpm --filter @skillkeeper/desktop dev",
    "build": "node scripts/gen-i18n.mjs && tsc -b tsconfig.build.json && pnpm --filter @skillkeeper/desktop run build",
    "build:libs": "node scripts/gen-i18n.mjs && tsc -b tsconfig.build.json",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "icons": "node scripts/gen-icons.mjs",
    "i18n": "node scripts/gen-i18n.mjs",
    "storybook": "pnpm --filter @skillkeeper/desktop run storybook",
    "docs:install": "node scripts/ensure-mkdocs.mjs",
    "docs:build": "node scripts/ensure-mkdocs.mjs build",
    "docs:serve": "node scripts/ensure-mkdocs.mjs serve"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "26.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "gettext-parser": "^8.0.0",
    "jimp": "^1.6.1",
    "prettier": "3.9.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}
