<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened-runtime entitlements for the SkillKeeper bundle. The rendering
    layer runs in a system WebView that uses a JIT, so the JIT and
    unsigned-executable-memory exceptions are retained.
  -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!--
    Keep library validation relaxed and allow dyld environment variables so
    dynamically loaded system frameworks (WebView, terminal helpers) load
    under the hardened runtime.
  -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <!--
    No file-access entitlements (com.apple.security.files.*) are listed: they
    only take effect under App Sandbox (com.apple.security.app-sandbox), which
    the dmg/app target does not enable, so the app already has full user-level
    file access. Runtime access to protected folders (Documents/Desktop/
    Downloads/removable volumes) is granted via TCC using the
    NS*UsageDescription strings in Info.plist. Add a sandboxed entitlements
    file only for a Mac App Store (mas) target.
  -->
</dict>
</plist>
