{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": [],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@skillkeeper/core": ["../../packages/core/src/index.ts"],
      "@skillkeeper/core/testing": ["../../packages/core/src/testing/index.ts"],
      "@skillkeeper/config": ["../../packages/config/src/index.ts"],
      "@skillkeeper/agents": ["../../packages/agents/src/index.ts"],
      "@skillkeeper/i18n/lazy": ["../../packages/i18n/src/lazy.ts"],
      "@skillkeeper/i18n": ["../../packages/i18n/src/index.ts"]
    }
  },
  "include": ["src/renderer/**/*"]
}
