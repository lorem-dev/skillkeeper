{
  "name": "@skillkeeper/desktop",
  "version": "0.0.0",
  "private": true,
  "author": "Lorem Dev",
  "homepage": "https://github.com/lorem-dev/skillkeeper",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "analyze": "electron-vite build --mode analyze",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.json",
    "package": "electron-builder",
    "package:dir": "electron-builder --dir",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "build": {
    "appId": "dev.lorem.skillkeeper",
    "productName": "SkillKeeper",
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!out/**/*.map",
      "node_modules/node-pty/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.svg",
      "category": "Development"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.svg",
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.svg"
    },
    "appx": {
      "applicationId": "SkillKeeper",
      "backgroundColor": "#1e40af",
      "displayName": "SkillKeeper",
      "identityName": "dev.lorem.SkillKeeper",
      "publisher": "CN=Lorem Dev",
      "publisherDisplayName": "Lorem Dev",
      "languages": [
        "en-US"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@skillkeeper/agents": "workspace:*",
    "@skillkeeper/config": "workspace:*",
    "@skillkeeper/core": "workspace:*",
    "@skillkeeper/i18n": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "motion": "12.42.0",
    "node-pty": "^1.1.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.1.0",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "sass": "1.101.0",
    "sonda": "0.13.1",
    "storybook": "10.4.6",
    "vite": "8.1.0"
  }
}
