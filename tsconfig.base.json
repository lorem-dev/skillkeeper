{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@skillkeeper/core": ["./packages/core/src/index.ts"],
      "@skillkeeper/core/testing": ["./packages/core/src/testing/index.ts"],
      "@skillkeeper/config": ["./packages/config/src/index.ts"],
      "@skillkeeper/agents": ["./packages/agents/src/index.ts"],
      "@skillkeeper/i18n": ["./packages/i18n/src/index.ts"]
    }
  }
}
